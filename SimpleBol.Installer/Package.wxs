<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="SimpleBol" Manufacturer="jKirkerx" Version="1.0.0.1" UpgradeCode="F4C98ED9-27DF-486F-9882-77768DA37E8F" Scope="perMachine">
    <MajorUpgrade DowngradeErrorMessage="A newer version of SimpleBol is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <SetProperty Id="ARPINSTALLLOCATION" Value="[INSTALLFOLDER]" After="CostFinalize" Sequence="both" />
    <Icon Id="SimpleBolIcon" SourceFile="$(var.SimpleBolIconPath)" />
    <Property Id="ARPPRODUCTICON" Value="SimpleBolIcon" />
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.EulaPath)" />
    <CustomAction Id="LaunchPrintNotifications" FileRef="PrintNotificationsExeFile" ExeCommand="--startup" Execute="immediate" Return="asyncNoWait" Impersonate="yes" />
    <CustomAction Id="StopPrintNotifications" Directory="INSTALLFOLDER" ExeCommand="&quot;[SystemFolder]taskkill.exe&quot; /IM SimpleBol.PrintNotifications.exe /T /F" Execute="deferred" Return="ignore" Impersonate="no" />
    <InstallExecuteSequence>
      <Custom Action="StopPrintNotifications" Before="RemoveFiles" Condition="(REMOVE=&quot;ALL&quot;) OR UPGRADINGPRODUCTCODE" />
      <Custom Action="LaunchPrintNotifications" After="InstallFinalize" Condition="NOT Installed" />
    </InstallExecuteSequence>
    <Feature Id="Main" Title="SimpleBol" Level="1">
      <ComponentGroupRef Id="ApplicationFiles" />
      <ComponentGroupRef Id="EmailTemplateFiles" />
      <ComponentGroupRef Id="StartMenuShortcuts" />
      <ComponentGroupRef Id="DesktopShortcuts" />
      <ComponentGroupRef Id="StartupShortcuts" />
    </Feature>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="SimpleBol">
        <Directory Id="AssetsFolder" Name="Assets">
          <Directory Id="EmailTemplatesFolder" Name="EmailTemplates" />
        </Directory>
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="SimpleBol" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />
    <StandardDirectory Id="StartupFolder" />
    <ComponentGroup Id="ApplicationFiles" Directory="INSTALLFOLDER">
      <Component Id="SimpleBolExe">
        <File Id="SimpleBolExeFile" Source="$(var.AppPublishDir)\SimpleBol.exe" KeyPath="yes" />
      </Component>
      <Component Id="PrintNotificationsExe">
        <File Id="PrintNotificationsExeFile" Source="$(var.NotificationsPublishDir)\SimpleBol.PrintNotifications.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>
    <ComponentGroup Id="EmailTemplateFiles" Directory="EmailTemplatesFolder">
      <Component Id="BolBillingIssueTemplate">
        <File Id="BolBillingIssueTemplateFile" Source="$(var.AppPublishDir)\Assets\EmailTemplates\bolBillingIssueToShipper.html" KeyPath="yes" />
      </Component>
    </ComponentGroup>
    <ComponentGroup Id="StartMenuShortcuts" Directory="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcutComponent">
        <Shortcut Id="SimpleBolStartMenuShortcut" Name="SimpleBol" Target="[#SimpleBolExeFile]" WorkingDirectory="INSTALLFOLDER" Icon="SimpleBolIcon" />
        <Shortcut Id="PrintNotificationsStartMenuShortcut" Name="SimpleBol Print Notifications" Target="[#PrintNotificationsExeFile]" WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\jKirkerx\SimpleBol" Name="StartMenuShortcuts" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>
    <ComponentGroup Id="DesktopShortcuts" Directory="DesktopFolder">
      <Component Id="DesktopShortcutComponent">
        <Shortcut Id="SimpleBolDesktopShortcut" Name="SimpleBol" Target="[#SimpleBolExeFile]" WorkingDirectory="INSTALLFOLDER" Icon="SimpleBolIcon" />
        <RegistryValue Root="HKCU" Key="Software\jKirkerx\SimpleBol" Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>
    <ComponentGroup Id="StartupShortcuts" Directory="StartupFolder">
      <Component Id="PrintNotificationsStartupComponent">
        <Shortcut Id="PrintNotificationsStartupShortcut" Name="SimpleBol Print Notifications" Target="[#PrintNotificationsExeFile]" WorkingDirectory="INSTALLFOLDER" Arguments="--startup" />
        <RegistryValue Root="HKCU" Key="Software\jKirkerx\SimpleBol" Name="PrintNotificationsStartup" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Package>
</Wix>
